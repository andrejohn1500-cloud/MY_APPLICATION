<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1B2A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Back -->
        <ImageButton
            android:id="@+id/btnPBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="#FFFFFF"/>

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏆 PLAYER PROFILE"
            android:textColor="#FFD700"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp"/>

        <!-- Avatar Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:gravity="center"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvPAvatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:textSize="48sp"
                android:gravity="center"
                android:background="@drawable/avatar_circle_bg"
                android:layout_marginBottom="10dp"/>

            <TextView
                android:id="@+id/tvPName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvPCountry"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#A8D8EA"
                android:textSize="16sp"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvPTier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/tier_badge_bg"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/loadingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="8dp"/>

        <!-- Stats Grid -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 STATS"
            android:textColor="#FFD700"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@drawable/stat_card_bg" android:gravity="center"
                android:padding="12dp" android:layout_marginEnd="6dp">
                <TextView android:id="@+id/tvPRating"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#FFD700" android:textSize="13sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@drawable/stat_card_bg" android:gravity="center"
                android:padding="12dp" android:layout_marginStart="6dp">
                <TextView android:id="@+id/tvPGames"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Games Played" android:textColor="#888" android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@drawable/stat_card_bg" android:gravity="center"
                android:padding="12dp" android:layout_marginEnd="6dp">
                <TextView android:id="@+id/tvPHighLevel"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#4CAF50" android:textSize="22sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Highest Level" android:textColor="#888" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@drawable/stat_card_bg" android:gravity="center"
                android:padding="12dp" android:layout_marginStart="6dp">
                <TextView android:id="@+id/tvPCleanRate"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#4CAF50" android:textSize="22sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Clean Rate" android:textColor="#888" android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@drawable/stat_card_bg" android:gravity="center"
                android:padding="12dp" android:layout_marginEnd="6dp">
                <TextView android:id="@+id/tvPBestScore"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#FFD700" android:textSize="22sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Best Score" android:textColor="#888" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical"
                android:background="@drawable/stat_card_bg" android:gravity="center"
                android:padding="12dp" android:layout_marginStart="6dp">
                <TextView android:id="@+id/tvPBestCat"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#A8D8EA" android:textSize="11sp" android:textStyle="bold"
                    android:gravity="center"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Best Category" android:textColor="#888" android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Clean Status -->
        <TextView
            android:id="@+id/tvPCleanStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/stat_card_bg"
            android:textColor="#90EE90"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="10dp"
            android:layout_marginBottom="12dp"/>

        <!-- Rank Progression -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎯 RANK PROGRESSION"
            android:textColor="#FFD700"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/stat_card_bg"
            android:padding="14dp"
            android:layout_marginBottom="24dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <TextView android:id="@+id/tvPTierLabel" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="🌱 Rookie" android:textColor="#FFFFFF" android:textSize="13sp"/>
                <TextView android:id="@+id/tvPNextTier" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#888"
                    android:textSize="13sp"/>
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressTier"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:max="100"
                android:progressTint="#FFD700"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:id="@+id/tvPProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#A8D8EA"
                android:textSize="12sp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
